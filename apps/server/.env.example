NODE_ENV=development
PORT=4000

MONGO_URI=mongodb://localhost:27017/tribastion
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_REFRESH_TTL_MS=604800000

SOCKET_JOIN_TOKEN_SECRET=replace-with-another-random-secret-at-least-32-chars

COOKIE_SECRET=replace-with-another-random-secret-at-least-32-chars
COOKIE_DOMAIN=

CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

MFA_ISSUER=Tribastion Quiz

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25

LOG_LEVEL=info
